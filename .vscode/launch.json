// flutter build apk --release --dart-define=app.flavor=prod
{
  "version": "1.1.0",
  "configurations": [
    {
      "name": "Dev - Emulador Android",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "dev",
        "--dart-define=app.flavor=dev",
        "--dart-define=app.env=development",
        "--verbose"
      ],
      "deviceId": "emulator-5554",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Dev - Dispositivo USB", // adb reverse tcp:8080 tcp:8080
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "dev",
        "--dart-define=app.flavor=dev",
        "--dart-define=app.env=development",
        "--verbose"
      ],
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Staging - Emulador",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "staging",
        "--dart-define=app.flavor=staging",
        "--dart-define=app.env=staging"
      ],
      "deviceId": "emulator-5554",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Produção - Release",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "prod",
        "--dart-define=app.flavor=prod",
        "--dart-define=app.env=production"
      ],
      "flutterMode": "release",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Web - Chrome",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "dev",
        "--dart-define=app.flavor=dev",
        "--dart-define=app.env=development",
        "-d",
        "chrome"
      ],
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Dev - Emulador + Logs",
      "configurations": ["Dev - Emulador Android"],
      "stopOnEntry": false,
      "description": "Inicia debug completo com logs verbosos em emulador"
    }
  ]
}
